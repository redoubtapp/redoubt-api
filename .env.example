# Redoubt Environment Variables
# Copy this file to .env and fill in the values for production deployment.
# For development, config.dev.yaml has hardcoded values so .env is not required.

# Database
POSTGRES_PASSWORD=your_secure_password_here

# Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here

# Storage (S3-compatible)
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
STORAGE_MASTER_KEY=base64_encoded_32_byte_key

# LiveKit
# These must match between the LiveKit server and the Go API
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Admin Panel
ADMIN_SESSION_SECRET=your_admin_session_secret_here

# Domain (used for TLS and client-facing LiveKit WebSocket URL)
DOMAIN=redoubt.example.com
